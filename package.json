{
  "name": "@vervstack/chures",
  "version": "0.0.1",
  "description": "React UI component library — Telegram auth, toasts, and more",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vervstack/telegram-auth"
  },
  "homepage": "https://github.com/vervstack/telegram-auth#readme",
  "keywords": [
    "telegram",
    "react",
    "oauth",
    "login",
    "widget",
    "ui",
    "components",
    "toaster"
  ],
  "type": "module",
  "main": "./dist/chures.umd.cjs",
  "module": "./dist/chures.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/chures.js",
      "require": "./dist/chures.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "demo": "vite",
    "build:demo": "vite build --config vite.config.demo.ts",
    "type-check": "tsc --noEmit",
    "patch": "npm version patch && npm publish --access public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.0",
    "framer-motion": "^12.0.0"
  },
  "devDependencies": {
    "@types/classnames": "^2.3.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "framer-motion": "^12.40.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.0.0",
    "zustand": "^5.0.14"
  },
  "dependencies": {
    "classnames": "^2.5.1"
  }
}
